# Sanity CMS (get values from https://sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Site URL for canonicals / OG (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://testenqa.github.io/vathala-web

# VaThala enquiry API (Book Appointment / callback modal)
NEXT_PUBLIC_VATHALA_API_URL=https://52.66.187.242:3001

# Optional: override embedded Turnstile site key (default is in src/lib/turnstile-config.ts)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# One-time migration only — do not commit .env.local
SANITY_API_WRITE_TOKEN=your_write_token

# Turnstile SECRET key — VaThala API server only (never NEXT_PUBLIC_, never commit)
# TURNSTILE_SECRET_KEY=your_turnstile_secret_from_cloudflare
